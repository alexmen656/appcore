# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appcore_aso?schema=public"

# App Store Connect API
# https://developer.apple.com/documentation/appstoreconnectapi/generating_tokens_for_api_requests
ASC_ISSUER_ID=
ASC_KEY_ID=
ASC_PRIVATE_KEY_PATH=./keys/AuthKey.p8
ASC_APP_ID=
ASC_BUNDLE_ID=eu.control-center.sites.kaloriq

# Apple Search Ads API
# https://developer.apple.com/documentation/apple_search_ads
APPLE_ADS_CLIENT_ID=
APPLE_ADS_CLIENT_SECRET=
APPLE_ADS_ORG_ID=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai  # openai | anthropic

# Scraping Config
SCRAPE_COUNTRY=de
SCRAPE_LANGUAGE=de
SCRAPE_INTERVAL_HOURS=24
MAX_COMPETITORS=20

# Multi-Locale ASO (comma-separated App Store Connect locales)
# Full list: en-US,en-GB,de-DE,fr-FR,es-ES,it-IT,pt-BR,ja,ko,zh-Hans,zh-Hant,nl-NL,ru,tr,ar-SA,sv,da,fi,nb,pl,cs,el,he,id,ms,vi,uk,ro,hu,sk,hr
ASO_LOCALES=en-US,de-DE

# Logging
LOG_LEVEL=info
