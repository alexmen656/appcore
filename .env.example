# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appcore?schema=public"

# Apple Search Ads API
# https://developer.apple.com/documentation/apple_search_ads
APPLE_ADS_CLIENT_ID=SEARCHADS.___________________________
APPLE_ADS_KEY_PATH=./keys/apple_ads_private_key.pem
APPLE_ADS_KEY_ID=___________________________
APPLE_ADS_TEAM_ID=SEARCHADS.___________________________
APPLE_ADS_ORG_ID=___________________________

GITHUB_CLIENT_ID=___________________________
GITHUB_CLIENT_SECRET=___________________________
GITHUB_WEBHOOK_BASE_URL=___________________________

# Fastlane Worker (MacOS)
FASTLANE_WORKER_SECRET="your-shared-secret-here"
FASTLANE_WORKER_URL=http://localhost:3200

# Logging
LOG_LEVEL=info

# APNs Push Notifications
APNS_KEY_ID=___________________________
APNS_TEAM_ID=___________________________
APNS_BUNDLE_ID=___________________________
APNS_KEY_PATH=./keys/AuthKey_<key_id>.p8
APNS_PRODUCTION=false◊

RESEND_API_KEY=____________________________
EMAIL_FROM="noreply@marteso.com" #example value
APP_URL="http://localhost:5173" #example value