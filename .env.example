# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/appcore_aso?schema=public"

# App Store Connect API
# https://developer.apple.com/documentation/appstoreconnectapi/generating_tokens_for_api_requests
ASC_ISSUER_ID=
ASC_KEY_ID=
ASC_PRIVATE_KEY_PATH=./keys/AuthKey.p8
ASC_APP_ID=
ASC_BUNDLE_ID=eu.control-center.sites.kaloriq

# Apple Search Ads API
# https://developer.apple.com/documentation/apple_search_ads
APPLE_ADS_CLIENT_ID=
APPLE_ADS_CLIENT_SECRET=
APPLE_ADS_ORG_ID=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai  # openai | anthropic

# Scraping Config
SCRAPE_COUNTRY=de
SCRAPE_LANGUAGE=de
SCRAPE_INTERVAL_HOURS=24
MAX_COMPETITORS=20

# Logging
LOG_LEVEL=info
