---
import Layout from "../layouts/Layout.astro";

const team = [
  {
    name: "Alex P.",
    initials: "AP",
    role: "Founder & CEO",
    bio: "Started building iOS apps in 2015. Got frustrated with the lack of good ASO tooling for small teams and built Marteso to solve it. Thinks obsessively about organic discovery and keyword strategy.",
    focus: ["Product strategy", "ASO research", "App development"],
    color: "accent",
  },
  {
    name: "Lena K.",
    initials: "LK",
    role: "Head of Growth & ASO",
    bio: "Former ASO consultant at a Berlin agency, where she managed keyword strategy for apps with 10M+ downloads. Now brings that experience directly into Marteso's tooling and content.",
    focus: ["Keyword strategy", "Competitor analysis", "Content"],
    color: "blue",
  },
  {
    name: "Marc R.",
    initials: "MR",
    role: "Lead Engineer",
    bio: "Full-stack developer with a decade of experience building data pipelines and consumer products. Responsible for Marteso's keyword tracking infrastructure and the ranking data engine.",
    focus: ["Backend infrastructure", "Data pipelines", "API design"],
    color: "green",
  },
  {
    name: "Julia B.",
    initials: "JB",
    role: "Product & Design",
    bio: "Designs and shapes every surface of Marteso — from the onboarding flow to the analytics dashboard. Previously product designer at a Series B fintech startup.",
    focus: ["UI/UX design", "Product thinking", "User research"],
    color: "yellow",
  },
  {
    name: "Tom S.",
    initials: "TS",
    role: "Data & Analytics",
    bio: "Statistician turned product engineer. Owns the ranking models and the signal processing behind Autonomous Mode — the system that detects ranking changes and surfaces recommendations proactively.",
    focus: ["Ranking models", "Autonomous Mode", "Data quality"],
    color: "accent",
  },
  {
    name: "Nora W.",
    initials: "NW",
    role: "Customer Success",
    bio: "Ensures every Marteso customer gets real results, not just a dashboard. Works directly with teams on their ASO strategy and translates product feedback into the roadmap.",
    focus: ["Onboarding", "Strategy calls", "Product feedback"],
    color: "blue",
  },
];

const colorMap: Record<string, { bg: string; text: string }> = {
  accent: { bg: "var(--accent-dim)", text: "var(--accent)" },
  blue: { bg: "var(--accent-blue-dim)", text: "var(--accent-blue)" },
  green: { bg: "rgba(74,222,128,0.12)", text: "#4ade80" },
  yellow: { bg: "rgba(251,191,36,0.12)", text: "#fbbf24" },
};
---

<Layout
  title="Team — Marteso"
  description="Meet the small, focused team behind Marteso. We're developers, designers, and ASO practitioners who build the tool we always wished existed."
  canonicalPath="/team"
>
  <div class="team-wrap">
    <div class="team-hero">
      <div class="section-label">Team</div>
      <h1>Small team, serious tool</h1>
      <p class="hero-lead">
        We're a compact, distributed team of engineers, designers, and ASO
        practitioners. Every person on this list has shipped mobile apps or
        managed App Store metadata professionally. We build Marteso because we
        use it.
      </p>
    </div>

    <div class="team-grid">
      {
        team.map((member) => {
          const c = colorMap[member.color];
          return (
            <div class="team-card">
              <div class="card-top">
                <div
                  class="member-avatar"
                  style={`background:${c.bg};color:${c.text};`}
                >
                  {member.initials}
                </div>
                <div>
                  <div class="member-name">{member.name}</div>
                  <div class="member-role" style={`color:${c.text};`}>
                    {member.role}
                  </div>
                </div>
              </div>
              <p class="member-bio">{member.bio}</p>
              <div class="member-focus">
                {member.focus.map((tag) => (
                  <span class="focus-tag">{tag}</span>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>

    <div class="divider"></div>

    <div class="hiring-section">
      <div class="hiring-inner">
        <div>
          <h2>We're a small team on purpose</h2>
          <p>
            We believe the best software is built by small groups of people who
            care deeply about the problem. Marteso will never become a 50-person
            company with a procurement process and a feature bloat problem. We
            grow slowly and deliberately.
          </p>
          <p>
            That said — we do occasionally look for people who combine strong
            technical skills with genuine interest in mobile app growth. If
            that's you, reach out.
          </p>
          <a
            href="mailto:hello@fringelo.com"
            class="btn btn-ghost"
            style="display:inline-flex;align-items:center;gap:6px;margin-top:8px;"
            >Get in touch ↗</a
          >
        </div>
        <div class="hiring-stat-stack">
          <div class="stat-card">
            <div class="stat-number">6</div>
            <div class="stat-label">Team members</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">3</div>
            <div class="stat-label">Countries</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">100%</div>
            <div class="stat-label">Remote</div>
          </div>
        </div>
      </div>
    </div>

    <div class="cta-section">
      <h2>Try Marteso free</h2>
      <p>No credit card. One app, 50 keywords, forever free.</p>
      <div class="cta-buttons">
        <a
          href="https://marteso.com/app/signup/"
          class="btn btn-primary btn-large">Start free</a
        >
        <a href="/about" class="btn btn-ghost btn-large">About Marteso →</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .team-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 140px 32px 120px;
  }

  .team-hero {
    margin-bottom: 64px;
    max-width: 680px;
  }

  h1 {
    font-size: 52px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 24px;
    color: var(--text-primary);
  }

  .hero-lead {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 80px;
  }

  .team-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .member-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    font-size: 15px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .member-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    margin-bottom: 3px;
  }

  .member-role {
    font-size: 13px;
    font-weight: 500;
  }

  .member-bio {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
  }

  .member-focus {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
  }

  .focus-tag {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-tertiary);
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
  }

  .divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 64px;
  }

  .hiring-section {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 48px;
    margin-bottom: 80px;
  }

  .hiring-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 64px;
    align-items: center;
  }

  .hiring-section h2 {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .hiring-section p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .hiring-stat-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
  }

  .stat-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 24px;
    text-align: center;
    min-width: 140px;
  }

  .stat-number {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .cta-section {
    text-align: center;
    padding: 64px 0 0;
  }

  .cta-section h2 {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    color: var(--text-primary);
  }

  .cta-section p {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }

  .cta-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .team-wrap {
      padding: 120px 20px 80px;
    }
    h1 {
      font-size: 36px;
    }
    .team-grid {
      grid-template-columns: 1fr;
    }
    .hiring-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hiring-stat-stack {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
