---
import Layout from '../layouts/Layout.astro';

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to get started with Marteso ASO",
  "description": "Connect your app and start growing organic downloads in minutes with Marteso.",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Connect your app",
      "text": "Link your App Store Connect or Google Play Console account via OAuth. Marteso syncs your app data, keyword rankings, download history, and review data automatically."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Discover your best keywords",
      "text": "Marteso surfaces the highest-opportunity keywords for your category, language, and target markets. Each keyword is scored by search volume, competition, and relevance."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Optimize your metadata",
      "text": "Use the AI-assisted metadata editor to write titles, subtitles, and descriptions. Real-time character counters and keyword density checks keep you inside store guidelines."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Test, measure, and iterate",
      "text": "A/B test icons, screenshots, and descriptions to maximize conversion. Weekly automated reports keep your team aligned on ASO performance."
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long does the initial setup take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most users are fully set up in under 10 minutes. Connecting your app store accounts, importing your app, and running your first keyword search takes about 3 minutes. The first full data sync completes in the background within the hour."
      }
    },
    {
      "@type": "Question",
      "name": "Does Marteso require special permissions on App Store Connect?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Marteso requests read-only access via OAuth 2.0. It never stores your App Store Connect password, and you can revoke access at any time from Apple's developer portal. Marteso never takes write actions on your account."
      }
    },
    {
      "@type": "Question",
      "name": "How often are keyword rankings updated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rankings are refreshed once every 24 hours per keyword per country. Pro plan users get priority refresh windows so their data is typically updated by 6 AM in the app's primary market."
      }
    },
    {
      "@type": "Question",
      "name": "Can I track keywords for a competitor's app?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. You can add any app from the App Store or Google Play as a competitor. Marteso tracks its keyword rankings, rating changes, and metadata edits over time — no login to that app's developer account required."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I exceed my keyword limit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "You'll receive a notification before you hit the limit. Existing tracked keywords continue to update uninterrupted. You can either upgrade your plan or remove keywords you no longer need."
      }
    }
  ]
};
---

<Layout
  title="How Marteso Works — Set Up ASO in Minutes"
  description="Connect your iOS or Android app and start growing organic downloads right away. Marteso syncs your data, surfaces keyword opportunities, and guides you through optimization."
  activeNav="how-it-works"
  canonicalPath="/how-it-works"
  jsonLd={[howToSchema, faqSchema]}
>
  <div class="page-header">
    <div class="section-label">How it works</div>
    <h1>Up and running in minutes</h1>
    <p class="page-description">
      Connect your app once. Marteso takes care of the data, surfacing exactly what you need to climb the charts and convert more users.
    </p>
  </div>

  <div class="steps-section">
    <div class="steps-timeline">

      <div class="timeline-step">
        <div class="step-indicator">
          <div class="step-circle">01</div>
        </div>
        <div class="step-content">
          <h2>Connect your app</h2>
          <p>Link your App Store Connect or Google Play Console account with OAuth — no passwords stored, no manual CSV uploads. Marteso immediately syncs your app's metadata, current keyword rankings, download history, and review data.</p>
          <div class="integrations">
            <div class="integration-pill"><div class="integration-dot" style="background:#007aff"></div>App Store Connect</div>
            <div class="integration-pill"><div class="integration-dot" style="background:#4ade80"></div>Google Play Console</div>
            <div class="integration-pill"><div class="integration-dot" style="background:var(--accent-blue)"></div>Slack notifications</div>
          </div>
          <div class="step-details" style="margin-top:24px;">
            <div class="detail-card"><h4>OAuth 2.0</h4><p>Secure, read-only access. Revoke at any time from your app store settings.</p></div>
            <div class="detail-card"><h4>Historical data</h4><p>We pull up to 90 days of ranking and review history on your first sync.</p></div>
            <div class="detail-card"><h4>Multiple apps</h4><p>Connect as many apps as your plan allows — iOS, Android, or both.</p></div>
          </div>
        </div>
      </div>

      <div class="timeline-step">
        <div class="step-indicator">
          <div class="step-circle">02</div>
        </div>
        <div class="step-content">
          <h2>Discover your best keywords</h2>
          <p>Marteso's keyword engine surfaces the highest-opportunity keywords for your category, language, and target markets. We score each keyword by search volume, competition, and relevance — so you know exactly where to spend your limited metadata characters.</p>
          <p>Add keywords to your tracking list with one click. Marteso then monitors your position for each keyword daily and sends alerts on meaningful moves.</p>
          <div class="step-details">
            <div class="detail-card"><h4>Volume scoring</h4><p>Relative search demand on a 0–100 scale, updated weekly per country.</p></div>
            <div class="detail-card"><h4>Difficulty rating</h4><p>How competitive the top 10 results are. Easy, Medium, or Hard.</p></div>
            <div class="detail-card"><h4>Gap analysis</h4><p>Find keywords your competitors rank for that you're currently missing.</p></div>
          </div>
        </div>
      </div>

      <div class="timeline-step">
        <div class="step-indicator">
          <div class="step-circle">03</div>
        </div>
        <div class="step-content">
          <h2>Optimize your metadata</h2>
          <p>Use the AI-assisted metadata editor to write titles, subtitles, and descriptions that pack in your target keywords without sounding robotic. Real-time character counters and keyword density checks keep you inside store guidelines as you type.</p>
          <div class="step-details">
            <div class="detail-card"><h4>AI suggestions</h4><p>Generate multiple variants of your title or description and pick the best one.</p></div>
            <div class="detail-card"><h4>Live validation</h4><p>Character counts, keyword density, and store compliance — all in real-time.</p></div>
            <div class="detail-card"><h4>Localization</h4><p>Manage metadata for all your store locales from a single interface.</p></div>
          </div>
        </div>
      </div>

      <div class="timeline-step">
        <div class="step-indicator">
          <div class="step-circle">04</div>
        </div>
        <div class="step-content">
          <h2>Test, measure, and iterate</h2>
          <p>A/B test icons, screenshots, and descriptions to maximize conversion. Marteso calculates statistical significance and tells you when a winner is clear. Weekly automated reports keep your entire team aligned on ASO performance without anyone having to log in.</p>
          <div class="step-details">
            <div class="detail-card"><h4>A/B testing</h4><p>Run store listing experiments with automatic winner detection.</p></div>
            <div class="detail-card"><h4>Weekly reports</h4><p>Email digests with rank changes, conversion trends, and top review insights.</p></div>
            <div class="detail-card"><h4>Slack alerts</h4><p>Get notified instantly when you break into a top-10 position or lose one.</p></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <section class="faq-section">
    <div class="faq-header">
      <div class="section-label">FAQ</div>
      <h2>Common questions</h2>
    </div>
    <div class="faq-item">
      <div class="faq-question">How long does the initial setup take?</div>
      <div class="faq-answer">Most users are fully set up in under 10 minutes. Connecting your app store accounts, importing your app, and running your first keyword search takes about 3 minutes. The first full data sync — pulling in rankings, reviews, and history — completes in the background within the hour.</div>
    </div>
    <div class="faq-item">
      <div class="faq-question">Does Marteso require special permissions on App Store Connect?</div>
      <div class="faq-answer">We request read-only access via OAuth 2.0. We never store your App Store Connect password, and you can revoke access at any time from within Apple's developer portal. We never take any write actions on your account.</div>
    </div>
    <div class="faq-item">
      <div class="faq-question">How often are keyword rankings updated?</div>
      <div class="faq-answer">Rankings are refreshed once every 24 hours per keyword per country. Pro plan users get priority refresh windows so their data is typically updated by 6 AM in the app's primary market.</div>
    </div>
    <div class="faq-item">
      <div class="faq-question">Can I track keywords for a competitor's app?</div>
      <div class="faq-answer">Yes. You can add any app from the App Store or Google Play as a competitor. Marteso tracks its keyword rankings, rating changes, and metadata edits over time — no login to that app's developer account required.</div>
    </div>
    <div class="faq-item">
      <div class="faq-question">What happens if I exceed my keyword limit?</div>
      <div class="faq-answer">You'll receive a notification before you hit the limit. Existing tracked keywords continue to update uninterrupted. You can either upgrade your plan or remove keywords you no longer need to stay within your quota.</div>
    </div>
  </section>

  <section class="cta">
    <h2>Start in minutes.</h2>
    <p>No credit card required. Connect your first app for free.</p>
    <div class="cta-buttons">
      <a href="https://marteso.com/app/signup/" class="btn btn-primary btn-large">Get started free</a>
      <a href="/features" class="btn btn-secondary btn-large">Explore features</a>
    </div>
  </section>
</Layout>

<style>
  .steps-section {
    max-width: 800px;
    margin: 0 auto 80px;
    padding: 0 32px;
  }

  .steps-timeline {
    position: relative;
  }

  .timeline-step {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 40px;
    padding: 48px 0;
    border-top: 1px solid var(--border);
  }

  .timeline-step:first-child { border-top: none; }

  .step-indicator { display: flex; flex-direction: column; align-items: center; padding-top: 4px; }

  .step-circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent-dim);
    border: 1px solid rgba(234, 14, 43, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    font-family: 'SF Mono', monospace;
    flex-shrink: 0;
  }

  .step-content h2 {
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .step-content > p {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .integrations {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 20px 0;
  }

  .integration-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 6px 14px;
    font-size: 13px;
    color: var(--text-secondary);
  }

  .integration-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .step-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .detail-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
  }

  .detail-card h4 {
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text-primary);
  }

  .detail-card p {
    font-size: 12px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .timeline-step { grid-template-columns: 1fr; gap: 16px; }
    .step-details { grid-template-columns: 1fr; }
  }
</style>
