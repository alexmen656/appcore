---
import Layout from "../layouts/Layout.astro";

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Marteso",
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  description:
    "ASO platform for mobile teams. Track keywords, optimize metadata, analyze competitors, and grow organic downloads on the App Store and Google Play.",
  url: "https://marteso.com",
  offers: [
    {
      "@type": "Offer",
      name: "Starter",
      price: "0",
      priceCurrency: "EUR",
      description:
        "Free plan for solo developers and early-stage teams: 1 app, 50 keywords, daily rank updates",
    },
    {
      "@type": "Offer",
      name: "Pro",
      price: "49",
      priceCurrency: "EUR",
      description:
        "Full ASO tooling: unlimited apps, 500 keywords, AI metadata optimizer, A/B testing",
    },
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "240",
  },
};
---

<Layout
  title="Marteso — App Store Optimization Platform for Mobile Teams"
  description="Marteso is the ASO platform for mobile teams. Track keywords, optimize metadata, analyze competitors, and grow organic downloads on the App Store and Google Play. Free plan available."
  canonicalPath="/"
  jsonLd={softwareSchema}
>
  <section class="hero">
    <div class="hero-content">
      <h1>Rank higher. Get downloaded more.</h1>
      <p class="hero-description">
        Marteso is the ASO platform for mobile teams. Track keywords, optimize
        metadata, analyze competitors, and grow your organic downloads - all in
        one place.
      </p>
      <div class="hero-buttons">
        <a
          href="https://marteso.com/app/signup/"
          class="btn btn-primary btn-large">Start for free</a
        >
        <a href="#features" class="btn btn-secondary btn-large">See features</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="browser-chrome">
        <div class="browser-header">
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
          <span class="browser-url">marteso.com / my-app / overview</span>
        </div>
        <div class="browser-content">
          <img
            src="/screenshot.jpg"
            alt="Example of Marteso dashboard showing keyword rankings and organic installs charts"
            style="width:100%; display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="logos">
    <div class="logos-inner">
      <p class="logos-label">Used by growth and ASO teams at</p>
      <div class="logos-grid">
        <span class="logo-item">Orbit Mobile</span>
        <span class="logo-item">Wavefront Apps</span>
        <span class="logo-item">Axiom Labs</span>
        <span class="logo-item">Spark Studio</span>
        <span class="logo-item">Crestline Games</span>
        <span class="logo-item">Nova Digital</span>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="section-label">By the numbers</div>
    <div class="stats-grid">
      <div class="stat">
        <h3>2.4M+</h3>
        <p>Keywords tracked</p>
      </div>
      <div class="stat">
        <h3>180+</h3>
        <p>Supported countries</p>
      </div>
      <div class="stat">
        <h3>+38%</h3>
        <p>Avg. organic growth after 60 days</p>
      </div>
      <div class="stat">
        <h3>iOS + Android</h3>
        <p>App Store & Google Play</p>
      </div>
    </div>
  </section>

  <section class="features" id="features">
    <div class="section-header">
      <div class="section-label">Features</div>
      <h2>Every ASO tool you need</h2>
      <p class="section-description">
        From keyword research to review management - Marteso covers the full ASO
        workflow.
      </p>
    </div>

    <div class="features-grid">
      <div class="feature">
        <div class="feature-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line>
          </svg>
        </div>
        <h3>Keyword Research</h3>
        <p>
          Discover high-volume, low-competition keywords for your category. Get
          search volume scores, difficulty ratings, and trend data for 180+
          countries.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
          </svg>
        </div>
        <h3>Rank Tracking</h3>
        <p>
          Monitor your keyword positions daily across the App Store and Google
          Play. Get instant alerts when you move up or drop out of the top
          results.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon blue">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"
            ></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"
            ></path>
          </svg>
        </div>
        <h3>Metadata Optimizer</h3>
        <p>
          AI-assisted title, subtitle, and description suggestions. See keyword
          density, character counts, and store guidelines in real-time as you
          write.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon blue">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
        </div>
        <h3>Competitor Analysis</h3>
        <p>
          Track competitors' keyword strategies, ratings, reviews, and metadata
          changes over time. Benchmark your store performance side by side.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
            ></path>
          </svg>
        </div>
        <h3>Review Management</h3>
        <p>
          Aggregate and analyze reviews from all storefronts. Detect sentiment
          trends, surface critical feedback, and respond directly from the
          dashboard.
        </p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
            <line x1="8" y1="21" x2="16" y2="21"></line>
            <line x1="12" y1="17" x2="12" y2="21"></line>
          </svg>
        </div>
        <h3>A/B Testing</h3>
        <p>
          Run icon, screenshot, and description experiments directly on the App
          Store. Measure conversion lift with statistical significance
          reporting.
        </p>
      </div>
    </div>
  </section>

  <section class="how-it-works" id="how-it-works">
    <div class="section-header">
      <div class="section-label">How it works</div>
      <h2>Up and running in minutes</h2>
      <p class="section-description">
        Connect your app and start growing organic downloads right away.
      </p>
    </div>

    <div class="steps-grid">
      <div class="step">
        <div class="step-number">01</div>
        <h3>Connect your app</h3>
        <p>
          Link your App Store Connect or Google Play Console account. Marteso
          pulls in your app data, current rankings, and review history
          automatically.
        </p>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <h3>Discover your keywords</h3>
        <p>
          Our research tool surfaces the best keyword opportunities for your
          category, language, and target market. Add them to your tracking list
          in one click.
        </p>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <h3>Optimize and measure</h3>
        <p>
          Apply the metadata suggestions, run A/B tests, and watch your rankings
          climb. Weekly reports keep your whole team aligned on ASO progress.
        </p>
      </div>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <div class="section-header">
      <div class="section-label">Pricing</div>
      <h2>Simple, transparent pricing</h2>
      <p class="section-description">
        Start for free. Upgrade as your app grows.
      </p>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card">
        <div class="pricing-tier">Starter</div>
        <div class="pricing-price"><sup>€</sup>0</div>
        <div class="pricing-period">forever free</div>
        <div class="pricing-description">
          For solo developers and early-stage apps getting started with ASO.
        </div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >1 app
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >50 keywords tracked
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Daily rank updates
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >3 competitor apps
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Review inbox
          </li>
        </ul>
        <a
          href="https://marteso.com/app/signup/"
          class="btn btn-secondary pricing-cta">Get started free</a
        >
      </div>

      <div class="pricing-card featured">
        <div class="pricing-badge">Most popular</div>
        <div class="pricing-tier">Pro</div>
        <div class="pricing-price"><sup>€</sup>49</div>
        <div class="pricing-period">per app / month</div>
        <div class="pricing-description">
          For growing apps that need deeper insights and full optimization
          tooling.
        </div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Unlimited apps
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >500 keywords tracked
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >AI metadata optimizer
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Unlimited competitors
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >A/B testing
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Weekly email reports
          </li>
        </ul>
        <a
          href="https://marteso.com/app/signup/"
          class="btn btn-primary pricing-cta">Start with Pro</a
        >
      </div>

      <div class="pricing-card">
        <div class="pricing-tier">Agency</div>
        <div class="pricing-price" style="font-size: 36px; padding-top: 8px;">
          Custom
        </div>
        <div class="pricing-period">talk to us</div>
        <div class="pricing-description">
          For agencies and studios managing multiple clients and dozens of apps.
        </div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Everything in Pro
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >White-label reports
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Client workspace management
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >API access
          </li>
          <li>
            <span class="check"
              ><svg
                viewBox="0 0 12 12"
                fill="none"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="2 6 5 9 10 3"></polyline></svg
              ></span
            >Dedicated account manager
          </li>
        </ul>
        <a
          href="mailto:hello@fringelo.com"
          class="btn btn-secondary pricing-cta">Contact sales</a
        >
      </div>
    </div>
  </section>

  <section class="testimonials">
    <div class="section-header">
      <div class="section-label">What teams say</div>
      <h2>ASO teams that ship faster</h2>
    </div>
    <div class="testimonials-grid">
      <div class="testimonial-card">
        <p class="testimonial-quote">
          "We moved off spreadsheets onto Marteso and haven't looked back.
          Keyword tracking across 12 markets is now a 10-minute check-in instead
          of a half-day project."
        </p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">SC</div>
          <div>
            <div class="testimonial-name">Sarah Chen</div>
            <div class="testimonial-role">Head of Growth · Orbit Mobile</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card">
        <p class="testimonial-quote">
          "The metadata optimizer alone paid for the subscription in the first
          month. We went from position 40 to top 5 for our core keyword in six
          weeks."
        </p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">MR</div>
          <div>
            <div class="testimonial-name">Marcus Reilly</div>
            <div class="testimonial-role">ASO Manager · Crestline Games</div>
          </div>
        </div>
      </div>
      <div class="testimonial-card">
        <p class="testimonial-quote">
          "Competitor monitoring used to be ad hoc. Now I get a Slack alert the
          moment a competitor updates their store listing. That kind of signal
          is genuinely useful."
        </p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">JV</div>
          <div>
            <div class="testimonial-name">Jana Voss</div>
            <div class="testimonial-role">Co-founder · Spark Studio</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Start growing today.</h2>
    <p>
      Join thousands of mobile teams using Marteso to climb the charts and
      convert more users organically.
    </p>
    <div class="cta-buttons">
      <a
        href="https://marteso.com/app/signup/"
        class="btn btn-primary btn-large">Start for free</a
      >
      <a href="https://marteso.com/docs/" class="btn btn-ghost btn-large"
        >Read the docs</a
      >
    </div>
  </section>
</Layout>

<style>
  .hero {
    margin-top: 64px;
    padding: 120px 32px 80px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-content {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    font-size: 64px;
  }

  .hero-description {
    font-size: 20px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 40px;
    font-weight: 400;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 80px;
  }

  .hero-visual {
    margin-top: 64px;
  }

  .browser-chrome {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .browser-header {
    height: 40px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 8px;
  }

  .browser-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border);
  }

  .browser-url {
    margin-left: 12px;
    font-size: 12px;
    color: var(--text-tertiary);
    font-family: "SF Mono", monospace;
  }

  .browser-content {
    background: var(--bg-secondary);
  }

  .logos {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 32px;
    border-top: 1px solid var(--border);
  }

  .logos-inner {
    display: flex;
    align-items: center;
    gap: 48px;
    flex-wrap: wrap;
  }

  .logos-label {
    font-size: 13px;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .logos-grid {
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .logo-item {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-tertiary);
    letter-spacing: -0.01em;
    transition: color 0.2s;
    cursor: default;
  }

  .logo-item:hover {
    color: var(--text-secondary);
  }

  /* Testimonials */
  .testimonials {
    max-width: 1200px;
    margin: 120px auto;
    padding: 0 32px;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .testimonial-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    transition: border-color 0.2s;
  }

  .testimonial-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .testimonial-quote {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .testimonial-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 600;
    color: var(--text-tertiary);
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .testimonial-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }

  .testimonial-role {
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  /* Stats */
  .stats {
    max-width: 1200px;
    margin: 0 auto 120px;
    padding: 80px 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 64px;
    margin-top: 48px;
  }

  .stat h3 {
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .stat p {
    font-size: 14px;
    color: var(--text-secondary);
  }

  /* Features grid */
  .features {
    max-width: 1200px;
    margin: 120px auto;
    padding: 0 32px;
  }

  .section-header {
    margin-bottom: 64px;
    text-align: center;
  }

  h2 {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-description {
    font-size: 18px;
