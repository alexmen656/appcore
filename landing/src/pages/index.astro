---
import Layout from '../layouts/Layout.astro';

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Marteso",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "description": "ASO platform for mobile teams. Track keywords, optimize metadata, analyze competitors, and grow organic downloads on the App Store and Google Play.",
  "url": "https://appcore.fringelo.com",
  "offers": [
    {
      "@type": "Offer",
      "name": "Starter",
      "price": "0",
      "priceCurrency": "EUR",
      "description": "Free plan for indie developers: 1 app, 50 keywords, daily rank updates"
    },
    {
      "@type": "Offer",
      "name": "Pro",
      "price": "49",
      "priceCurrency": "EUR",
      "description": "Full ASO tooling: unlimited apps, 500 keywords, AI metadata optimizer, A/B testing"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "240"
  }
};
---

<Layout
  title="Marteso — App Store Optimization Platform for Mobile Teams"
  description="Marteso is the ASO platform for mobile teams. Track keywords, optimize metadata, analyze competitors, and grow organic downloads on the App Store and Google Play. Free plan available."
  canonicalPath="/"
  jsonLd={softwareSchema}
>
  <section class="hero">
    <div class="hero-content">
      <h1>Rank higher. Get downloaded more.</h1>
      <p class="hero-description">
        Marteso is the ASO platform for mobile teams. Track keywords, optimize metadata,
        analyze competitors, and grow your organic downloads - all in one place.
      </p>
      <div class="hero-buttons">
        <a href="https://marteso.com/app/signup/" class="btn btn-primary btn-large">Start for free</a>
        <a href="#features" class="btn btn-secondary btn-large">See features</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="browser-chrome">
        <div class="browser-header">
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
          <div class="browser-dot"></div>
          <span class="browser-url">marteso.com / my-app / overview</span>
        </div>
        <div class="browser-content">
          <img
            src="/screenshot.png"
            alt="Example of Marteso dashboard showing keyword rankings and organic installs charts"
            style="width:100%; display:block;"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="stats">
    <div class="section-label">Trusted by mobile teams</div>
    <div class="stats-grid">
      <div class="stat">
        <h3>2.4M+</h3>
        <p>Keywords tracked</p>
      </div>
      <div class="stat">
        <h3>180+</h3>
        <p>Supported countries</p>
      </div>
      <div class="stat">
        <h3>+38%</h3>
        <p>Avg. organic growth after 60 days</p>
      </div>
      <div class="stat">
        <h3>iOS + Android</h3>
        <p>App Store & Google Play</p>
      </div>
    </div>
  </section>

  <section class="features" id="features">
    <div class="section-header">
      <div class="section-label">Features</div>
      <h2>Every ASO tool you need</h2>
      <p class="section-description">
        From keyword research to review management - Marteso covers the full ASO workflow.
      </p>
    </div>

    <div class="features-grid">
      <div class="feature">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </div>
        <h3>Keyword Research</h3>
        <p>Discover high-volume, low-competition keywords for your category. Get search volume scores, difficulty ratings, and trend data for 180+ countries.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3>Rank Tracking</h3>
        <p>Monitor your keyword positions daily across the App Store and Google Play. Get instant alerts when you move up or drop out of the top results.</p>
      </div>
      <div class="feature">
        <div class="feature-icon blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
        </div>
        <h3>Metadata Optimizer</h3>
        <p>AI-assisted title, subtitle, and description suggestions. See keyword density, character counts, and store guidelines in real-time as you write.</p>
      </div>
      <div class="feature">
        <div class="feature-icon blue">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3>Competitor Analysis</h3>
        <p>Track competitors' keyword strategies, ratings, reviews, and metadata changes over time. Benchmark your store performance side by side.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3>Review Management</h3>
        <p>Aggregate and analyze reviews from all storefronts. Detect sentiment trends, surface critical feedback, and respond directly from the dashboard.</p>
      </div>
      <div class="feature">
        <div class="feature-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
        </div>
        <h3>A/B Testing</h3>
        <p>Run icon, screenshot, and description experiments directly on the App Store. Measure conversion lift with statistical significance reporting.</p>
      </div>
    </div>
  </section>

  <section class="how-it-works" id="how-it-works">
    <div class="section-header">
      <div class="section-label">How it works</div>
      <h2>Up and running in minutes</h2>
      <p class="section-description">Connect your app and start growing organic downloads right away.</p>
    </div>

    <div class="steps-grid">
      <div class="step">
        <div class="step-number">01</div>
        <h3>Connect your app</h3>
        <p>Link your App Store Connect or Google Play Console account. Marteso pulls in your app data, current rankings, and review history automatically.</p>
      </div>
      <div class="step">
        <div class="step-number">02</div>
        <h3>Discover your keywords</h3>
        <p>Our research tool surfaces the best keyword opportunities for your category, language, and target market. Add them to your tracking list in one click.</p>
      </div>
      <div class="step">
        <div class="step-number">03</div>
        <h3>Optimize and measure</h3>
        <p>Apply the metadata suggestions, run A/B tests, and watch your rankings climb. Weekly reports keep your whole team aligned on ASO progress.</p>
      </div>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <div class="section-header">
      <div class="section-label">Pricing</div>
      <h2>Simple, transparent pricing</h2>
      <p class="section-description">Start for free. Upgrade as your app grows.</p>
    </div>

    <div class="pricing-grid">
      <div class="pricing-card">
        <div class="pricing-tier">Starter</div>
        <div class="pricing-price"><sup>€</sup>0</div>
        <div class="pricing-period">forever free</div>
        <div class="pricing-description">For indie developers and early-stage apps getting started with ASO.</div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>1 app</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>50 keywords tracked</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Daily rank updates</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>3 competitor apps</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Review inbox</li>
        </ul>
        <a href="https://marteso.com/app/signup/" class="btn btn-secondary pricing-cta">Get started free</a>
      </div>

      <div class="pricing-card featured">
        <div class="pricing-badge">Most popular</div>
        <div class="pricing-tier">Pro</div>
        <div class="pricing-price"><sup>€</sup>49</div>
        <div class="pricing-period">per app / month</div>
        <div class="pricing-description">For growing apps that need deeper insights and full optimization tooling.</div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Unlimited apps</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>500 keywords tracked</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>AI metadata optimizer</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Unlimited competitors</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>A/B testing</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Weekly email reports</li>
        </ul>
        <a href="https://marteso.com/app/signup/" class="btn btn-primary pricing-cta">Start with Pro</a>
      </div>

      <div class="pricing-card">
        <div class="pricing-tier">Agency</div>
        <div class="pricing-price" style="font-size: 36px; padding-top: 8px;">Custom</div>
        <div class="pricing-period">talk to us</div>
        <div class="pricing-description">For agencies and studios managing multiple clients and dozens of apps.</div>
        <div class="pricing-divider"></div>
        <ul class="pricing-features-list">
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Everything in Pro</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>White-label reports</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Client workspace management</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>API access</li>
          <li><span class="check"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Dedicated account manager</li>
        </ul>
        <a href="mailto:hello@fringelo.com" class="btn btn-secondary pricing-cta">Contact sales</a>
      </div>
    </div>
  </section>

  <section class="cta">
    <h2>Start growing today.</h2>
    <p>Join hundreds of mobile teams using Marteso to climb the charts and convert more users organically.</p>
    <div class="cta-buttons">
      <a href="https://marteso.com/app/signup/" class="btn btn-primary btn-large">Start for free</a>
      <a href="https://docs.fringelo.com/" class="btn btn-ghost btn-large">Read the docs</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    margin-top: 64px;
    padding: 120px 32px 80px;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-content {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    font-size: 64px;
  }

  .hero-description {
    font-size: 20px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 40px;
    font-weight: 400;
  }

  .hero-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 80px;
  }

  .hero-visual {
    margin-top: 64px;
  }

  .browser-chrome {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  }

  .browser-header {
    height: 40px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 8px;
  }

  .browser-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--border);
  }

  .browser-url {
    margin-left: 12px;
    font-size: 12px;
    color: var(--text-tertiary);
    font-family: 'SF Mono', monospace;
  }

  .browser-content {
    background: var(--bg-secondary);
  }

  /* Stats */
  .stats {
    max-width: 1200px;
    margin: 0 auto 120px;
    padding: 80px 32px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    text-align: center;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 64px;
    margin-top: 48px;
  }

  .stat h3 {
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .stat p {
    font-size: 14px;
    color: var(--text-secondary);
  }

  /* Features grid */
  .features {
    max-width: 1200px;
    margin: 120px auto;
    padding: 0 32px;
  }

  .section-header {
    margin-bottom: 64px;
    text-align: center;
  }

  h2 {
    font-size: 40px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .section-description {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .feature {
    background: var(--bg-secondary);
    padding: 40px 32px;
    transition: background 0.2s;
  }

  .feature:hover {
    background: var(--bg-tertiary);
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    background: var(--accent-dim);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .feature-icon svg {
    stroke: var(--accent);
  }

  .feature-icon.blue {
    background: var(--accent-blue-dim);
  }

  .feature-icon.blue svg {
    stroke: var(--accent-blue);
  }

  .feature h3 {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .feature p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* How it works */
  .how-it-works {
    max-width: 1200px;
    margin: 120px auto;
    padding: 0 32px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .step {
    background: var(--bg-secondary);
    padding: 40px 32px;
  }

  .step-number {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.05em;
    margin-bottom: 16px;
    font-family: 'SF Mono', monospace;
  }

  .step h3 {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* Pricing section */
  .pricing {
    max-width: 1200px;
    margin: 120px auto;
    padding: 0 32px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-visual {
      animation: fadeInUp 0.8s ease-out;
    }

    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(40px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }

  @media (max-width: 768px) {
    h1 { font-size: 40px; }
    .hero-description { font-size: 18px; }
    .features-grid, .steps-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
  }
</style>
