---
import Layout from "../../layouts/Layout.astro";
import { posts, type Post } from "../../data/posts";

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: Post };

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.excerpt,
  datePublished: post.date,
  author: {
    "@type": "Person",
    name: post.author.name,
  },
  publisher: {
    "@type": "Organization",
    name: "Marteso",
    logo: "https://marteso.com/logo.svg",
  },
};

const related = posts
  .filter((p) => p.slug !== post.slug && p.category === post.category)
  .slice(0, 2)
  .concat(
    posts
      .filter((p) => p.slug !== post.slug && p.category !== post.category)
      .slice(0, 2),
  )
  .slice(0, 2);
---

<Layout
  title={`${post.title} — Marteso Blog`}
  description={post.excerpt}
  activeNav="blog"
  canonicalPath={`/blog/${post.slug}`}
  jsonLd={jsonLd}
>
  <div class="article-wrap">
    <div class="article-header">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <div class="post-meta">
        <span class={`post-category ${post.catClass}`}>{post.category}</span>
        <span class="post-date">{post.date}</span>
      </div>
      <h1>{post.title}</h1>
      <p class="article-lead">{post.excerpt}</p>
      <div class="author-row">
        <div class="author-avatar">{post.author.initials}</div>
        <span class="author-name">{post.author.name}</span>
        <span class="read-time">· {post.readTime}</span>
      </div>
    </div>

    <div class="article-divider"></div>

    <article class="article-body">
      {
        post.content.map((section) => {
          if (section.type === "h2") {
            return <h2>{section.text}</h2>;
          }
          if (section.type === "p") {
            return <p>{section.text}</p>;
          }
          if (section.type === "ul") {
            return (
              <ul>
                {section.items?.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            );
          }
          if (section.type === "callout") {
            return <div class="callout">{section.text}</div>;
          }
          return null;
        })
      }
    </article>

    {
      related.length > 0 && (
        <section class="related">
          <h3>More from the blog</h3>
          <div class="related-grid">
            {related.map((r) => (
              <a href={`/blog/${r.slug}`} class="related-card">
                <div class="post-meta">
                  <span class={`post-category ${r.catClass}`}>
                    {r.category}
                  </span>
                  <span class="post-date">{r.date}</span>
                </div>
                <h4>{r.title}</h4>
                <p>{r.excerpt}</p>
                <div class="related-footer">
                  <div class="author-avatar sm">{r.author.initials}</div>
                  <span class="author-name">{r.author.name}</span>
                  <span class="read-time">· {r.readTime}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </div>
</Layout>

<style>
  .article-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 140px 32px 120px;
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--text-tertiary);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .article-header {
    margin-bottom: 40px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .post-category {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .cat-aso {
    background: var(--accent-dim);
    color: var(--accent);
  }
  .cat-growth {
    background: rgba(74, 222, 128, 0.12);
    color: #4ade80;
  }
  .cat-product {
    background: var(--accent-blue-dim);
    color: var(--accent-blue);
  }
  .cat-guide {
    background: rgba(251, 191, 36, 0.12);
    color: #fbbf24;
  }

  .post-date {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  h1 {
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .article-lead {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 24px;
  }

  .author-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-avatar.sm {
    width: 24px;
    height: 24px;
    font-size: 10px;
  }

  .author-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .read-time {
    font-size: 13px;
    color: var(--text-tertiary);
  }

  .article-divider {
    height: 1px;
    background: var(--border);
    margin-bottom: 48px;
  }

  /* Article body */
  .article-body h2 {
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-top: 48px;
    margin-bottom: 16px;
    line-height: 1.3;
  }

  .article-body p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .article-body ul {
    margin: 0 0 24px 0;
    padding-left: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .article-body li {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.65;
    padding-left: 20px;
    position: relative;
  }

  .article-body li::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 600;
  }

  .callout {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 0 8px 8px 0;
    padding: 16px 20px;
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 32px 0;
  }

  /* Related posts */
  .related {
    margin-top: 80px;
    padding-top: 48px;
    border-top: 1px solid var(--border);
  }

  .related h3 {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .related-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
    text-decoration: none;
    transition: border-color 0.2s;
    display: flex;
    flex-direction: column;
  }

  .related-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .related-card h4 {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .related-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }

  .related-footer {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .article-wrap {
      padding: 120px 20px 80px;
    }
    h1 {
      font-size: 28px;
    }
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
