---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Marteso Features — Keyword Research, Rank Tracking, A/B Testing & More"
  description="Marteso covers the full ASO workflow: keyword research across 180+ countries, daily rank tracking, AI metadata optimizer, competitor analysis, review management, and A/B testing."
  activeNav="features"
  canonicalPath="/features"
>
  <div class="page-header">
    <div class="section-label">Features</div>
    <h1>Every ASO tool in one place</h1>
    <p class="page-description">
      From keyword discovery to review management — Marteso covers the full App Store Optimization workflow for iOS and Android.
    </p>
  </div>

  <div class="feature-section">
    <div class="feature-block">
      <div class="feature-text">
        <div class="feature-tag">Keyword Research</div>
        <h2>Find keywords that actually rank</h2>
        <p>Discover high-volume, low-competition keywords for your category across 180+ countries and all languages. Get real search volume scores, difficulty ratings, and trend data — so you invest your metadata budget where it counts.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Search volume &amp; difficulty scores for every keyword</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>180+ countries, all App Store categories</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Trending keywords and seasonal demand signals</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Competitor keyword gap analysis</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">Keyword Research · productivity</span>
        </div>
        <div class="panel-body">
          <div class="kw-list">
            <div class="kw-item"><span class="kw-pill">productivity app</span><span class="kw-vol">Vol 94</span><span class="kw-diff easy">Easy</span></div>
            <div class="kw-item"><span class="kw-pill">task manager</span><span class="kw-vol">Vol 87</span><span class="kw-diff easy">Easy</span></div>
            <div class="kw-item"><span class="kw-pill">to do list app</span><span class="kw-vol">Vol 81</span><span class="kw-diff medium">Medium</span></div>
            <div class="kw-item"><span class="kw-pill">project planner</span><span class="kw-vol">Vol 72</span><span class="kw-diff medium">Medium</span></div>
            <div class="kw-item"><span class="kw-pill">focus timer pomodoro</span><span class="kw-vol">Vol 68</span><span class="kw-diff hard">Hard</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="feature-block reverse">
      <div class="feature-text">
        <div class="feature-tag">Rank Tracking</div>
        <h2>Know your position. Every day.</h2>
        <p>Monitor keyword rankings daily across the App Store and Google Play. Get instant alerts the moment you break into the top 10 — or when a competitor overtakes you. Historical charts let you correlate ranking changes with metadata updates.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Daily rank updates for all tracked keywords</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Instant alerts for rank changes above threshold</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>90-day historical charts per keyword</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>iOS &amp; Android side-by-side view</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">Rank Tracker · App Store · DE</span>
        </div>
        <div class="panel-body">
          <div class="rank-chart">
            <div class="rank-row"><span class="rank-label">productivity app</span><div class="rank-bar-bg"><div class="rank-bar" style="width:92%"></div></div><span class="rank-pos">#3</span><span class="rank-delta">↑2</span></div>
            <div class="rank-row"><span class="rank-label">task manager</span><div class="rank-bar-bg"><div class="rank-bar" style="width:76%"></div></div><span class="rank-pos">#7</span><span class="rank-delta">↑1</span></div>
            <div class="rank-row"><span class="rank-label">to do list app</span><div class="rank-bar-bg"><div class="rank-bar" style="width:62%"></div></div><span class="rank-pos">#11</span><span class="rank-delta">↑4</span></div>
            <div class="rank-row"><span class="rank-label">project planner</span><div class="rank-bar-bg"><div class="rank-bar" style="width:44%"></div></div><span class="rank-pos">#19</span><span class="rank-delta down">↓1</span></div>
            <div class="rank-row"><span class="rank-label">focus timer</span><div class="rank-bar-bg"><div class="rank-bar blue" style="width:34%"></div></div><span class="rank-pos">#24</span><span class="rank-delta">–</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="feature-block">
      <div class="feature-text">
        <div class="feature-tag blue">Metadata Optimizer</div>
        <h2>AI-assisted titles, subtitles &amp; descriptions</h2>
        <p>Write store listings that rank and convert. Our AI optimizer suggests metadata based on your top keywords, checks character limits in real-time, and shows keyword density so you never waste precious title space.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>AI-generated title and subtitle suggestions</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Live character count with store guideline limits</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Keyword density and placement analysis</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Multi-locale support with one-click translation</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">Metadata Editor · My Productivity App</span>
        </div>
        <div class="panel-body">
          <div class="meta-editor">
            <div class="meta-field"><label>App Name <span class="chars">28 / 30</span></label><div class="meta-input">Focus Flow – Task Manager Pro</div></div>
            <div class="meta-field"><label>Subtitle <span class="chars">25 / 30</span></label><div class="meta-input">Productivity &amp; To-Do Planner</div></div>
            <div class="meta-field"><label>Keywords field <span class="chars">88 / 100</span></label><div class="meta-input" style="font-size:12px;color:var(--text-secondary);">task,planner,todo,focus,timer,pomodoro,goals,habits,work</div></div>
            <div class="ai-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              3 AI suggestions available
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="feature-block reverse">
      <div class="feature-text">
        <div class="feature-tag blue">Competitor Analysis</div>
        <h2>See exactly what your competitors are doing</h2>
        <p>Track any competitor's keyword strategy, review trends, ratings, and metadata changes over time. Benchmark your store performance side by side, and find the keyword gaps you can exploit.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Track any app's keyword rankings</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Metadata change history and alerts</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Rating and review volume benchmarks</li>
          <li><span class="bullet-icon blue"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Keyword gap report: what they rank for that you don't</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">Competitor Intelligence</span>
        </div>
        <div class="panel-body">
          <div style="display:flex;flex-direction:column;gap:10px;">
            <div style="font-size:11px;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px;">Keyword gap · My App vs. Competitor</div>
            <div style="background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:12px;color:var(--text-secondary);">habit tracker</span><span style="font-size:11px;color:#4ade80;font-weight:600;">Only competitor #2</span></div>
            <div style="background:var(--bg-primary);border:1px solid var(--border);border-radius:6px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:12px;color:var(--text-secondary);">daily planner</span><span style="font-size:11px;color:#4ade80;font-weight:600;">Only competitor #5</span></div>
            <div style="background:var(--accent-dim);border:1px solid rgba(234,14,43,0.2);border-radius:6px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:12px;color:var(--text-primary);font-weight:500;">goal setting app</span><span style="font-size:11px;color:var(--accent);font-weight:600;">You're missing this</span></div>
            <div style="background:var(--accent-dim);border:1px solid rgba(234,14,43,0.2);border-radius:6px;padding:10px 12px;display:flex;justify-content:space-between;align-items:center;"><span style="font-size:12px;color:var(--text-primary);font-weight:500;">work schedule planner</span><span style="font-size:11px;color:var(--accent);font-weight:600;">You're missing this</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="feature-block">
      <div class="feature-text">
        <div class="feature-tag">Review Management</div>
        <h2>Understand and respond to every review</h2>
        <p>Aggregate reviews from all storefronts and countries in one inbox. AI sentiment analysis surfaces what users love, what frustrates them, and what drives uninstalls — so your product team can prioritize with confidence.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Unified inbox for App Store &amp; Google Play</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>AI sentiment and topic categorization</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Respond directly from the dashboard</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Rating trend alerts and version-level breakdown</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">Reviews · Sentiment Overview</span>
        </div>
        <div class="panel-body">
          <div class="review-list">
            <div class="review-card"><div class="review-top"><span class="review-stars">★★★★★</span><span class="review-date">2 days ago</span></div><p class="review-text">"Finally an app that doesn't get in my way. The focus timer is perfect."</p></div>
            <div class="review-card"><div class="review-top"><span class="review-stars" style="color:#fbbf24">★★★</span><span class="review-date">5 days ago</span></div><p class="review-text">"Good app but syncing with calendar is broken since the last update."</p></div>
          </div>
          <div style="margin-top:14px;">
            <div style="font-size:11px;color:var(--text-tertiary);margin-bottom:8px;text-transform:uppercase;letter-spacing:.06em;">Sentiment · last 30 days</div>
            <div class="sentiment-bar"><span class="sentiment-label">Positive</span><div class="sentiment-track"><div class="sentiment-fill positive" style="width:72%"></div></div><span class="sentiment-pct">72%</span></div>
            <div class="sentiment-bar"><span class="sentiment-label">Neutral</span><div class="sentiment-track"><div class="sentiment-fill neutral" style="width:18%"></div></div><span class="sentiment-pct">18%</span></div>
            <div class="sentiment-bar"><span class="sentiment-label">Negative</span><div class="sentiment-track"><div class="sentiment-fill negative" style="width:10%"></div></div><span class="sentiment-pct">10%</span></div>
          </div>
        </div>
      </div>
    </div>

    <div class="feature-block reverse">
      <div class="feature-text">
        <div class="feature-tag">A/B Testing</div>
        <h2>Test your way to better conversion</h2>
        <p>Run icon, screenshot, and description experiments directly on the App Store. Marteso tracks impression-to-install rates, calculates statistical significance, and tells you when a winner is clear — no data science degree required.</p>
        <ul class="feature-bullets">
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Icon, screenshots, and description experiments</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Statistical significance reporting</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Conversion rate lift measurement</li>
          <li><span class="bullet-icon"><svg viewBox="0 0 12 12" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 5 9 10 3"/></svg></span>Automatic winner detection and alerts</li>
        </ul>
      </div>
      <div class="feature-visual">
        <div class="panel-header">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span class="panel-title">A/B Test · Icon experiment</span>
        </div>
        <div class="panel-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div style="background:var(--bg-primary);border:1px solid var(--border);border-radius:8px;padding:14px;text-align:center;">
              <div style="width:56px;height:56px;border-radius:14px;background:var(--accent-dim);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
              <div style="font-size:11px;color:var(--text-tertiary);">Variant A</div>
              <div style="font-size:18px;font-weight:600;margin:4px 0;">32.1%</div>
              <div style="font-size:11px;color:var(--text-secondary);">conv. rate</div>
            </div>
            <div style="background:var(--bg-primary);border:1px solid rgba(74,222,128,0.3);border-radius:8px;padding:14px;text-align:center;">
              <div style="width:56px;height:56px;border-radius:14px;background:rgba(74,222,128,0.1);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
              <div style="font-size:11px;color:#4ade80;font-weight:600;">Variant B · WINNER</div>
              <div style="font-size:18px;font-weight:600;margin:4px 0;color:#4ade80;">38.7%</div>
              <div style="font-size:11px;color:var(--text-secondary);">conv. rate</div>
            </div>
          </div>
          <div style="margin-top:12px;padding:10px 12px;background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.2);border-radius:6px;text-align:center;"><span style="font-size:12px;color:#4ade80;font-weight:500;">↑ +6.6 pp lift · 95% confidence</span></div>
        </div>
      </div>
    </div>

  </div>

  <section class="cta">
    <h2>Ready to grow?</h2>
    <p>Start for free, no credit card required.</p>
    <div class="cta-buttons">
      <a href="https://marteso.com/app/signup/" class="btn btn-primary btn-large">Start for free</a>
      <a href="/pricing" class="btn btn-secondary btn-large">View pricing</a>
    </div>
  </section>
</Layout>

<style>
  .feature-section {
    max-width: 1200px;
    margin: 0 auto 120px;
    padding: 0 32px;
  }

  .feature-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding: 80px 0;
    border-top: 1px solid var(--border);
  }

  .feature-block:first-child { border-top: none; }

  .feature-block.reverse { direction: rtl; }
  .feature-block.reverse > * { direction: ltr; }

  .feature-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-dim);
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .feature-tag.blue {
    background: var(--accent-blue-dim);
    color: var(--accent-blue);
  }

  h2 {
    font-size: 36px;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    line-height: 1.15;
  }

  .feature-text p {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .feature-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .feature-bullets li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .bullet-icon {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--accent-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .bullet-icon svg { width: 10px; height: 10px; stroke: var(--accent); }
  .bullet-icon.blue { background: var(--accent-blue-dim); }
  .bullet-icon.blue svg { stroke: var(--accent-blue); }

  .feature-visual {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    min-height: 320px;
    display: flex;
    flex-direction: column;
  }

  .panel-header {
    height: 40px;
    background: var(--bg-tertiary);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 8px;
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--border); }

  .panel-title {
    margin-left: 8px;
    font-size: 12px;
    color: var(--text-tertiary);
    font-weight: 500;
  }

  .panel-body { padding: 24px; flex: 1; }

  /* Keyword list */
  .kw-list { display: flex; flex-direction: column; gap: 10px; }
  .kw-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; background: var(--bg-primary); border: 1px solid var(--border); border-radius: 6px; }
  .kw-pill { font-size: 13px; font-weight: 500; color: var(--text-primary); flex: 1; }
  .kw-vol { font-size: 11px; color: var(--text-tertiary); width: 60px; text-align: right; }
  .kw-diff { font-size: 11px; font-weight: 600; padding: 2px 6px; border-radius: 3px; width: 44px; text-align: center; }
  .kw-diff.easy { background: rgba(74,222,128,0.12); color: #4ade80; }
  .kw-diff.medium { background: rgba(251,191,36,0.12); color: #fbbf24; }
  .kw-diff.hard { background: var(--accent-dim); color: var(--accent); }

  /* Rank chart */
  .rank-chart { display: flex; flex-direction: column; gap: 8px; }
  .rank-row { display: flex; align-items: center; gap: 10px; }
  .rank-label { font-size: 12px; color: var(--text-secondary); width: 110px; flex-shrink: 0; }
  .rank-bar-bg { flex: 1; height: 6px; background: var(--bg-tertiary); border-radius: 3px; }
  .rank-bar { height: 6px; border-radius: 3px; background: var(--accent); }
  .rank-bar.blue { background: var(--accent-blue); }
  .rank-pos { font-size: 12px; font-weight: 600; width: 28px; text-align: right; }
  .rank-delta { font-size: 11px; color: #4ade80; width: 24px; text-align: right; }
  .rank-delta.down { color: var(--accent); }

  /* Metadata editor */
  .meta-editor { display: flex; flex-direction: column; gap: 14px; }
  .meta-field label { font-size: 11px; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.06em; display: flex; justify-content: space-between; margin-bottom: 6px; }
  .meta-field .chars { color: var(--accent-blue); }
  .meta-input { background: var(--bg-primary); border: 1px solid var(--border); border-radius: 6px; padding: 10px 12px; font-size: 13px; color: var(--text-primary); line-height: 1.5; }
  .ai-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--accent-blue-dim); color: var(--accent-blue); font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 4px; margin-top: 8px; }

  /* Reviews */
  .review-list { display: flex; flex-direction: column; gap: 10px; }
