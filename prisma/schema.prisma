generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ───────────────────────────────────────────────────────────

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  role         UserRole      @default(USER)
  settings     UserSettings?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([email])
}

enum UserRole {
  ADMIN
  USER
}

/// Per-user configuration stored in the DB (replaces .env for multi-user)
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── App Store Connect ────────────────────────────────────────────────
  ascIssuerId   String?
  ascKeyId      String?
  ascPrivateKey String? // PEM content (not a file path)
  ascAppId      String?
  ascBundleId   String?

  // ── AI Provider ──────────────────────────────────────────────────────
  openaiApiKey    String?
  anthropicApiKey String?
  aiProvider      String? @default("openai") // openai | anthropic

  // ── Scraping ─────────────────────────────────────────────────────────
  scrapeCountry       String? @default("us")
  scrapeIntervalHours Int?    @default(24)
  maxCompetitors      Int?    @default(20)

  // ── Multi-locale ASO ─────────────────────────────────────────────────
  asoLocales String? @default("en-US") // comma-separated, e.g. "en-US,de-DE"

  // ── Analytics ────────────────────────────────────────────────────────
  ascVendorNumber          String? // required for Sales Reports API

  // ── MCP Integration ───────────────────────────────────────────────────
  mcpEnabled  Boolean @default(false)
  mcpApiKey   String? // UUID-basierter Key, null bis erstmalig generiert

  // ── GitHub Integration ────────────────────────────────────────────────
  githubAccessToken  String?  // OAuth access token
  githubUsername     String?  // GitHub login
  githubAvatarUrl    String?  // avatar_url
  githubConnectedAt  DateTime?

  updatedAt DateTime @updatedAt
}

// ─── Our App ────────────────────────────────────────────────────────────────

model App {
  id            String   @id @default(cuid())
  bundleId      String   @unique
  name          String
  trackId       BigInt?     @unique // Apple's numeric ID
  country       String   @default("de")
  isOwnApp      Boolean  @default(false)

  // Current ASO metadata (synced from App Store Connect)
  currentTitle       String?
  currentSubtitle    String?
  currentKeywords    String?  // comma-separated
  currentDescription String?

  // Per-app Apple Analytics ONGOING request ID (persisted across syncs)
  analyticsRequestId String?
  // ONE_TIME_SNAPSHOT request ID – polled until all historical data is fetched
  analyticsSnapshotRequestId String?

  // GitHub repo link
  githubRepoOwner    String?   // e.g. "octocat"
  githubRepoName     String?   // e.g. "my-ios-app"
  githubRepoFullName String?   // e.g. "octocat/my-ios-app"
  githubWebhookId    BigInt?   // GitHub webhook ID for cleanup
  githubWebhookSecret String?  // random HMAC secret per app

  // iOS code signing (base64-encoded, stored per app)
  signingCertP12        String?  // base64 .p12 certificate
  signingCertPassword   String?  // password for the .p12
  signingProvisioningProfile String?  // base64 .mobileprovision
  signingTeamId         String?  // Apple Team ID (e.g. "ABC123XYZ")

  // Tracking
  snapshots     AppSnapshot[]
  rankings      KeywordRanking[]
  competitors   CompetitorRelation[] @relation("app_competitors")
  competitorOf  CompetitorRelation[] @relation("competitor_of")
  screenshotJobs ScreenshotJob[]
  asoExperiments AsoExperiment[]
  competitorReviews   CompetitorReview[]
  reviewSummaries     CompetitorReviewSummary[]
  metadataChanges     AppMetadataChange[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([bundleId])
  @@index([country])
}

// ─── Snapshots of app metadata over time ─────────────────────────────────

model AppSnapshot {
  id             String   @id @default(cuid())
  appId          String
  app            App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  // Scraped metadata
  title          String
  subtitle       String?
  description    String
  keywords       String?   // if available (only for our own app via ASC)
  rating         Float?
  ratingsCount   Int?
  price           Float?
  version        String?
  releaseNotes   String?
  screenshotUrls String[]  // array of URLs
  iconUrl        String?
  developerName  String?
  category       String?
  categoryId     Int?

  // Computed metrics
  descriptionLength  Int?
  wordCount          Int?
  readabilityScore   Float?

  scrapedAt      DateTime @default(now())

  @@index([appId, scrapedAt])
  @@index([scrapedAt])
}

// ─── Keywords we track ──────────────────────────────────────────────────

model Keyword {
  id          String   @id @default(cuid())
  term        String
  country     String   @default("de")
  language    String   @default("de")

  // Search Ads data
  popularity     Float?   // Apple Search Ads popularity score
  difficulty     Float?   // estimated difficulty
  searchVolume   Int?     // estimated monthly searches

  rankings    KeywordRanking[]
  suggestions ASOSuggestion[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([term, country])
  @@index([term])
  @@index([popularity])
}

// ─── Keyword ranking snapshots ──────────────────────────────────────────

model KeywordRanking {
  id          String   @id @default(cuid())
  keywordId   String
  keyword     Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  rank        Int?     // null = not ranked
  country     String   @default("de")

  trackedAt   DateTime @default(now())

  @@index([keywordId, trackedAt])
  @@index([appId, trackedAt])
  @@index([trackedAt])
}

// ─── Competitor relationships ───────────────────────────────────────────

model CompetitorRelation {
  id            String   @id @default(cuid())
  appId         String
  app           App      @relation("app_competitors", fields: [appId], references: [id], onDelete: Cascade)
  competitorId  String
  competitor    App      @relation("competitor_of", fields: [competitorId], references: [id], onDelete: Cascade)

  relevanceScore Float?   // AI-computed relevance 0-1
  addedAt        DateTime @default(now())

  @@unique([appId, competitorId])
}

// ─── AI-generated ASO suggestions ───────────────────────────────────────

model ASOSuggestion {
  id              String   @id @default(cuid())

  // What was suggested
  type            SuggestionType
  locale          String   @default("en-US") // ASC locale (en-US, de-DE, etc.)
  suggestedValue  String
  reasoning       String    // AI explanation

  // Context
  appBundleId     String?   // which app this suggestion belongs to
  currentValue    String?
  keywordId       String?
  keyword         Keyword?  @relation(fields: [keywordId], references: [id])

  // Scoring
  confidenceScore Float?    // 0-1
  estimatedImpact Float?    // 0-1

  // Status tracking
  status          SuggestionStatus @default(PENDING)
  appliedAt       DateTime?
  resultNotes     String?

  // AI metadata
  aiProvider      String    // openai | anthropic
  aiModel         String
  promptTokens    Int?
  completionTokens Int?

  createdAt       DateTime @default(now())

  @@index([type, status])
  @@index([locale, status])
  @@index([createdAt])
}

enum SuggestionType {
  TITLE
  SUBTITLE
  KEYWORDS
  DESCRIPTION
  SCREENSHOT_ORDER
}

enum SuggestionStatus {
  PENDING
  APPROVED
  APPLIED
  REJECTED
  EXPIRED
}

// ─── Scrape job tracking ────────────────────────────────────────────────

model ScrapeJob {
  id          String      @id @default(cuid())
  type        ScrapeType
  status      JobStatus   @default(PENDING)
  result      String?     // JSON summary
  error       String?
  itemsCount  Int         @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([type, status])
  @@index([createdAt])
}

enum ScrapeType {
  COMPETITOR_METADATA
  KEYWORD_RANKING
  SEARCH_ADS_DATA
  OWN_APP_SYNC
  KEYWORD_DISCOVERY
  ASC_ANALYTICS
  FASTLANE_SUBMIT
}

// ─── App Store Connect Analytics ────────────────────────────────────────────

model AppStoreAnalytics {
  id          String   @id @default(cuid())
  bundleId    String
  reportDate  DateTime // the day this row represents (midnight UTC)
  country     String   // 2-letter country code, e.g. "DE", "US"
  downloads   Int      @default(0) // new installs (product type 1 / 1F)
  updates     Int      @default(0) // re-downloads / updates (product type 1T)
  reDownloads Int      @default(0) // re-downloads counted separately
  proceeds    Float    @default(0) // Developer Proceeds (revenue in USD)

  // From Apple Analytics Reports API (App Store Engagement report)
  impressions Int      @default(0) // total impressions (search + browse)
  pageViews   Int      @default(0) // product page views
  sessions    Int      @default(0) // unique sessions / active devices

  createdAt   DateTime @default(now())

  @@unique([bundleId, reportDate, country])
  @@index([bundleId, reportDate])
}

model AppReview {
  id               String   @id @default(cuid())
  ascReviewId      String   @unique // ASC's own review ID
  bundleId         String
  rating           Int // 1–5
  title            String?
  body             String?
  reviewerNickname String?
  territory        String? // e.g. "DEU", "USA"
  reviewedAt       DateTime // createdDate from ASC
  createdAt        DateTime @default(now())

  @@index([bundleId, reviewedAt])
}

// ─── Competitor Reviews (scraped from App Store) ────────────────────────

model CompetitorReview {
  id               String   @id @default(cuid())
  appId            String
  app              App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  externalId       String?  // external review ID for deduplication
  rating           Int      // 1–5
  title            String?
  body             String?
  author           String?
  territory        String?  // e.g. "de", "us"
  reviewedAt       DateTime
  createdAt        DateTime @default(now())

  @@unique([appId, externalId])
  @@index([appId, reviewedAt])
  @@index([appId, rating])
}

// ─── AI-generated review summaries per competitor ───────────────────────

model CompetitorReviewSummary {
  id              String   @id @default(cuid())
  appId           String
  app             App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  reviewCount     Int      // how many reviews went into this summary
  averageRating   Float
  summary         String   // AI-generated summary text
  strengths       String[] // key strengths extracted
  weaknesses      String[] // key weaknesses extracted
  topThemes       String[] // main themes (e.g. "performance", "ui", "price")
  sentiment       String?  // overall sentiment: positive | mixed | negative
  aiProvider      String
  aiModel         String
  createdAt       DateTime @default(now())

  @@index([appId, createdAt])
}

// ─── Competitor metadata change tracking ────────────────────────────────

model AppMetadataChange {
  id          String   @id @default(cuid())
  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  field       String   // title | subtitle | description | keywords | version | rating | price
  oldValue    String?
  newValue    String?
  detectedAt  DateTime @default(now())

  @@index([appId, detectedAt])
  @@index([appId, field])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Push Notification Device Tokens ────────────────────────────────────

model DeviceToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String?  // optional link to a user
  bundleId    String?  // app bundle ID
  platform    String   @default("ios") // ios | android
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

// ─── Push Notification Log ──────────────────────────────────────────────

model PushNotificationLog {
  id          String   @id @default(cuid())
  deviceToken String
  title       String
  body        String
  category    String?  // KEYWORD_RANK_UPDATE, SUBMISSION_UPDATE, JOB_COMPLETE
  data        Json?    // additional payload data
  status      String   @default("sent") // sent | failed | delivered
  error       String?

  sentAt      DateTime @default(now())

  @@index([category, sentAt])
}

// ─── Screenshot generation from GitHub pushes ──────────────────────────

model ScreenshotJob {
  id            String    @id @default(cuid())
  appId         String
  app           App       @relation(fields: [appId], references: [id], onDelete: Cascade)

  commitSha     String
  commitMessage String?
  branch        String?
  pusher        String?   // GitHub username who pushed

  status        JobStatus @default(PENDING)
  logs          String?   // JSON stringified log lines
  error         String?
  screenshotUrls String[] // resulting screenshot URLs / paths

  // Framed (App Store ready) screenshots, keyed by locale
  // e.g. { "de-DE": ["/screenshots/jobId/framed/de-DE/...png"], ... }
  framedByLocale Json?

  // Raw descriptions from fastlane/screenshot_descriptions.json
  // e.g. { "04_Community": "Community tab with posts and social interactions" }
  screenshotDescriptions Json?

  // AI-generated optimized sublines per locale per screenshot
  // e.g. { "en-US": { "04_Community": "Connect & Share Adventures" }, "de-DE": { ... } }
  screenshotSublines Json?

  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([appId, createdAt])
  @@index([commitSha])
}

// ─── Autonomous ASO Experiments ─────────────────────────────────────────

model AsoExperiment {
  id              String               @id @default(cuid())
  appId           String
  app             App                  @relation(fields: [appId], references: [id], onDelete: Cascade)

  type            AsoExperimentType
  fromValue       String?
  toValue         String?
  reason          String?              // AI explanation
  confidence      Float                // 0.0 – 1.0

  status          AsoExperimentStatus  @default(PENDING)

  // Outcome tracking
  rankBefore      Int?
  rankAfter       Int?
  impressionsDelta Int?

  deployedAt      DateTime?
  evaluatedAt     DateTime?
  createdAt       DateTime             @default(now())

  @@index([appId, status])
  @@index([status, deployedAt])
  @@index([createdAt])
}

enum AsoExperimentType {
  KEYWORD_ADD
  KEYWORD_REMOVE
  KEYWORD_REPLACE
  TITLE_CHANGE
  SUBTITLE_CHANGE
}

enum AsoExperimentStatus {
  PENDING
  APPROVED
  DEPLOYED
  EVALUATED
  REJECTED
}
