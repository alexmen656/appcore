generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        String        @id @default(cuid())
  name      String
  members   TeamMember[]
  invites   TeamInvite[]
  apps      App[]
  settings  TeamSettings?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model TeamMember {
  id        String                @id @default(cuid())
  teamId    String
  team      Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      TeamRole              @default(MEMBER)
  appAccess TeamMemberAppAccess[]
  createdAt DateTime              @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model TeamMemberAppAccess {
  id           String     @id @default(cuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  appId        String
  app          App        @relation(fields: [appId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([teamMemberId, appId])
  @@index([teamMemberId])
}

model TeamInvite {
  id         String    @id @default(cuid())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  email      String
  role       TeamRole  @default(MEMBER)
  token      String    @unique
  invitedBy  String
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([teamId])
  @@index([token])
  @@index([email])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id           String              @id @default(cuid())
  email        String              @unique
  name         String?
  passwordHash String?
  role         UserRole            @default(USER)
  passkeys     PasskeyCredential[]
  teamMembers  TeamMember[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([email])
}

model PasskeyCredential {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String    @default("singleDevice")
  backedUp     Boolean   @default(false)
  transports   String[]
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
}

enum UserRole {
  ADMIN
  USER
}

model TeamSettings {
  id                String    @id @default(cuid())
  teamId            String    @unique
  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  ascIssuerId       String?
  ascKeyId          String?
  ascPrivateKey     String?
  openaiApiKey      String?
  anthropicApiKey   String?
  aiProvider        String?   @default("openai")
  ascVendorNumber   String?
  mcpEnabled        Boolean   @default(false)
  githubAccessToken String?
  githubUsername    String?
  githubAvatarUrl   String?
  githubConnectedAt DateTime?
  updatedAt         DateTime  @updatedAt
}

model App {
  id                         String                    @id @default(cuid())
  bundleId                   String                    @unique
  name                       String
  teamId                     String?
  team                       Team?                     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  trackId                    BigInt?                   @unique
  country                    String                    @default("de")
  isOwnApp                   Boolean                   @default(false)
  currentTitle               String?
  currentSubtitle            String?
  currentKeywords            String?
  currentDescription         String?
  analyticsRequestId         String?
  analyticsSnapshotRequestId String?
  githubRepoOwner            String?
  githubRepoName             String?
  githubRepoFullName         String?
  githubWebhookId            BigInt?
  githubWebhookSecret        String?
  githubIosDir               String?
  signingCertP12             String?
  signingCertPassword        String?
  signingProvisioningProfile String?
  signingTeamId              String?
  snapshotEnvVars            String?
  memberAccess               TeamMemberAppAccess[]
  snapshots                  AppSnapshot[]
  rankings                   KeywordRanking[]
  competitors                CompetitorRelation[]      @relation("app_competitors")
  competitorOf               CompetitorRelation[]      @relation("competitor_of")
  screenshotJobs             ScreenshotJob[]
  buildJobs                  BuildJob[]
  asoExperiments             AsoExperiment[]
  competitorReviews          CompetitorReview[]
  reviewSummaries            CompetitorReviewSummary[]
  metadataChanges            AppMetadataChange[]
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  @@index([bundleId])
  @@index([country])
  @@index([teamId])
}

model AppSnapshot {
  id                String   @id @default(cuid())
  appId             String
  app               App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  title             String
  subtitle          String?
  description       String
  keywords          String?
  rating            Float?
  ratingsCount      Int?
  price             Float?
  version           String?
  releaseNotes      String?
  screenshotUrls    String[]
  iconUrl           String?
  developerName     String?
  category          String?
  categoryId        Int?
  descriptionLength Int?
  wordCount         Int?
  readabilityScore  Float?
  scrapedAt         DateTime @default(now())

  @@index([appId, scrapedAt])
  @@index([scrapedAt])
}

model Keyword {
  id           String           @id @default(cuid())
  term         String
  country      String           @default("de")
  language     String           @default("de")
  popularity   Float?
  difficulty   Float?
  searchVolume Int?
  rankings     KeywordRanking[]
  suggestions  ASOSuggestion[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([term, country])
  @@index([term])
  @@index([popularity])
}

model KeywordRanking {
  id        String   @id @default(cuid())
  keywordId String
  keyword   Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  appId     String
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  rank      Int?
  country   String   @default("de")
  trackedAt DateTime @default(now())

  @@index([keywordId, trackedAt])
  @@index([appId, trackedAt])
  @@index([trackedAt])
}

model CompetitorRelation {
  id             String   @id @default(cuid())
  appId          String
  app            App      @relation("app_competitors", fields: [appId], references: [id], onDelete: Cascade)
  competitorId   String
  competitor     App      @relation("competitor_of", fields: [competitorId], references: [id], onDelete: Cascade)
  relevanceScore Float?
  addedAt        DateTime @default(now())

  @@unique([appId, competitorId])
}

model ASOSuggestion {
  id               String           @id @default(cuid())
  type             SuggestionType
  locale           String           @default("en-US")
  suggestedValue   String
  reasoning        String
  appBundleId      String?
  currentValue     String?
  keywordId        String?
  keyword          Keyword?         @relation(fields: [keywordId], references: [id])
  confidenceScore  Float?
  estimatedImpact  Float?
  status           SuggestionStatus @default(PENDING)
  appliedAt        DateTime?
  resultNotes      String?
  aiProvider       String
  aiModel          String
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime         @default(now())

  @@index([type, status])
  @@index([locale, status])
  @@index([createdAt])
}

enum SuggestionType {
  TITLE
  SUBTITLE
  KEYWORDS
  DESCRIPTION
  SCREENSHOT_ORDER
}

enum SuggestionStatus {
  PENDING
  APPROVED
  APPLIED
  REJECTED
  EXPIRED
}

model AppStoreAnalytics {
  id          String   @id @default(cuid())
  bundleId    String
  reportDate  DateTime
  country     String
  downloads   Int      @default(0)
  updates     Int      @default(0)
  reDownloads Int      @default(0)
  proceeds    Float    @default(0)
  impressions Int      @default(0)
  pageViews   Int      @default(0)
  sessions    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([bundleId, reportDate, country])
  @@index([bundleId, reportDate])
}

model AppReview {
  id               String   @id @default(cuid())
  ascReviewId      String   @unique
  bundleId         String
  rating           Int
  title            String?
  body             String?
  reviewerNickname String?
  territory        String?
  reviewedAt       DateTime
  createdAt        DateTime @default(now())

  @@index([bundleId, reviewedAt])
}

model CompetitorReview {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  externalId String?
  rating     Int
  title      String?
  body       String?
  author     String?
  territory  String?
  reviewedAt DateTime
  createdAt  DateTime @default(now())

  @@unique([appId, externalId])
  @@index([appId, reviewedAt])
  @@index([appId, rating])
}

model CompetitorReviewSummary {
  id            String   @id @default(cuid())
  appId         String
  app           App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  reviewCount   Int
  averageRating Float
  summary       String
  strengths     String[]
  weaknesses    String[]
  topThemes     String[]
  sentiment     String?
  aiProvider    String
  aiModel       String
  createdAt     DateTime @default(now())

  @@index([appId, createdAt])
}

model AppMetadataChange {
  id         String   @id @default(cuid())
  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  field      String
  oldValue   String?
  newValue   String?
  detectedAt DateTime @default(now())

  @@index([appId, detectedAt])
  @@index([appId, field])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model OAuthClient {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientSecret String
  name         String
  userId       String?
  redirectUris String[]
  createdAt    DateTime @default(now())

  @@index([userId])
}

model OAuthCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String
  userId              String
  redirectUri         String
  codeChallenge       String?
  codeChallengeMethod String?
  expiresAt           DateTime
  used                Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([expiresAt])
}

model OAuthToken {
  id          String   @id @default(cuid())
  accessToken String   @unique
  clientId    String
  userId      String
  createdAt   DateTime @default(now())
}

model DeviceToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String?
  bundleId  String?
  platform  String   @default("ios")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model PushNotificationLog {
  id          String   @id @default(cuid())
  deviceToken String
  title       String
  body        String
  category    String?
  data        Json?
  status      String   @default("sent")
  error       String?
  sentAt      DateTime @default(now())

  @@index([category, sentAt])
}

model ScreenshotJob {
  id                     String    @id @default(cuid())
  appId                  String
  app                    App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  commitSha              String
  commitMessage          String?
  branch                 String?
  pusher                 String?
  status                 JobStatus @default(PENDING)
  logs                   String?
  error                  String?
  screenshotUrls         String[]
  framedByLocale         Json?
  screenshotDescriptions Json?
  screenshotSublines     Json?
  startedAt              DateTime?
  completedAt            DateTime?
  createdAt              DateTime  @default(now())

  @@index([appId, createdAt])
  @@index([commitSha])
}

model BuildJob {
  id          String    @id @default(cuid())
  appId       String
  app         App       @relation(fields: [appId], references: [id], onDelete: Cascade)
  branch      String?
  commitSha   String?
  status      JobStatus @default(PENDING)
  logs        String?
  errors      String?
  ipaPath     String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([appId, createdAt])
}

model AsoExperiment {
  id               String              @id @default(cuid())
  appId            String
  app              App                 @relation(fields: [appId], references: [id], onDelete: Cascade)
  type             AsoExperimentType
  fromValue        String?
  toValue          String?
  reason           String?
  confidence       Float
  status           AsoExperimentStatus @default(PENDING)
  rankBefore       Int?
  rankAfter        Int?
  impressionsDelta Int?
  deployedAt       DateTime?
  evaluatedAt      DateTime?
  createdAt        DateTime            @default(now())

  @@index([appId, status])
  @@index([status, deployedAt])
  @@index([createdAt])
}

enum AsoExperimentType {
  KEYWORD_ADD
  KEYWORD_REMOVE
  KEYWORD_REPLACE
  TITLE_CHANGE
  SUBTITLE_CHANGE
}

enum AsoExperimentStatus {
  PENDING
  APPROVED
  DEPLOYED
  EVALUATED
  REJECTED
}
